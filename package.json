{
  "name": "claude-code-bg-process-manager",
  "version": "2.0.0",
  "description": "MCP server for background process management in Claude Code on Windows",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bg-manager": "dist/index.js"
  },
  "files": [
    "dist",
    "web/dist"
  ],
  "scripts": {
    "build:web": "cd web && npm install --ignore-scripts && npm run build",
    "build:server": "tsc",
    "build": "npm run build:web && npm run build:server",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "background-process",
    "process-manager",
    "windows",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AndrewKirkovski/claude-code-bg-process-manager-windows"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.8.0",
    "node-pty": "^1.1.0",
    "shell-quote": "^1.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/shell-quote": "^1.7.5",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2"
  }
}
